{
  "name": "devlog",
  "version": "0.1.0",
  "private": true,
  "description": "Developer micro-blogging platform \u2014 TILs, code snippets, and dev notes with markdown and syntax highlighting",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
